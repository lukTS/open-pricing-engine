{
  "name": "open-pricing-engine-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Configurable open-source pricing engine",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b packages/core"
  },
  "keywords": [
    "pricing",
    "engine",
    "calculator"
  ],
  "author": "lukTS",
  "license": "MIT",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
